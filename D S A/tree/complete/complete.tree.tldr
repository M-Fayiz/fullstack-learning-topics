							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "            queue.push(current.left)"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
