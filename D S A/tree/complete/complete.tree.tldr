							},
							"content": [
								{
									"type": "text",
									"text": "function isComplete(node){"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "  "
